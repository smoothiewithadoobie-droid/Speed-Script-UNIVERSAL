Section(P_Remotes, "Fire Remote")
local ArgsBox = Input(P_Remotes, 'Args: comma separated — true, 42, "hello"')

local function parseArg(s)
    s = s:match("^%s*(.-)%s*$")
    if s == "true" then return true end
    if s == "false" then return false end
    if s == "nil" then return nil end
    local n = tonumber(s); if n then return n end
    return s:match('^"(.*)"$') or s:match("^'(.*)'$") or s
end

local function parseArgs(raw)
    local args = {}
    for seg in (raw..","):gmatch("([^,]*),") do
        local t = seg:match("^%s*(.-)%s*$")
        if t ~= "" then table.insert(args, parseArg(t)) end
    end
    return args
end

Button(P_Remotes, "Fire Selected Remote", Theme.Accent, function()
    if not selectedRemote or not selectedRemote.Parent then
        Library:Notify("Remotes", "No remote selected", 2); return
    end
    local args = parseArgs(ArgsBox.Text)
    local ok, err = pcall(function()
        if selectedRemote:IsA("RemoteEvent") then
            selectedRemote:FireServer(table.unpack(args))
        elseif selectedRemote:IsA("RemoteFunction") then
            local result = selectedRemote:InvokeServer(table.unpack(args))
            Library:Notify("Remotes", "Result: "..tostring(result), 4)
        end
    end)
    if ok then
        Library:Notify("Remotes", "Fired: "..selectedRemote.Name, 2)
    else
        Library:Notify("Error", tostring(err):sub(1,60), 4)
    end
end)

