local ESPFolder = Instance.new("Folder")
ESPFolder.Name = "SmoothiesESP"; ESPFolder.Parent = CoreGui
local espObjects = {}

local function getESPColor(p)
    if state.espTeamColor and p.Team then return p.TeamColor.Color end
    local cols = {
        Color3.fromRGB(168,85,247), Color3.fromRGB(236,72,153),
        Color3.fromRGB(56,189,248), Color3.fromRGB(74,222,128)
    }
    return cols[(p.UserId % #cols) + 1]
end

local function buildESPForPlayer(p)
    if p == player or espObjects[p] then return end
    local c = {}; espObjects[p] = c

    local hl = Instance.new("Highlight")
    hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    hl.FillTransparency = 0.75; hl.OutlineTransparency = 0
    hl.OutlineColor = getESPColor(p); hl.FillColor = getESPColor(p)
    hl.Parent = ESPFolder; c.highlight = hl

    local bb = Instance.new("BillboardGui")
    bb.Size = UDim2.fromOffset(120,50); bb.StudsOffset = Vector3.new(0,3.5,0)
    bb.AlwaysOnTop = true; bb.ResetOnSpawn = false
    bb.Parent = ESPFolder; c.bbGui = bb

    local function mkLabel(size, pos, font, textSize, color)
        local l = Instance.new("TextLabel")
        l.Size = size; l.Position = pos; l.BackgroundTransparency = 1
        l.Font = font; l.TextSize = textSize; l.TextColor3 = color
        l.TextStrokeTransparency = 0.5; l.TextStrokeColor3 = Color3.new(0,0,0)
        l.Parent = bb; return l
    end

    c.nameLabel = mkLabel(UDim2.new(1,0,0,20), UDim2.new(0,0,0,0),  Enum.Font.GothamBold, 13, getESPColor(p))
    c.distLabel = mkLabel(UDim2.new(1,0,0,16), UDim2.new(0,0,0,20), Enum.Font.Code,       11, Theme.TextDim)
    c.hpLabel   = mkLabel(UDim2.new(1,0,0,14), UDim2.new(0,0,0,36), Enum.Font.Code,       11, Theme.Success)
    c.nameLabel.Text = p.DisplayName
    c.distLabel.Text = "0 studs"
    c.hpLabel.Text   = "HP: 100"

    local function attach(char)
        if not char then return end
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if hrp then hl.Adornee = char; bb.Adornee = hrp end
    end
    attach(p.Character)
    p.CharacterAdded:Connect(function(char)
        task.wait(0.5); attach(char)
        hl.OutlineColor = getESPColor(p); hl.FillColor = getESPColor(p)
        c.nameLabel.TextColor3 = getESPColor(p)
    end)
end

local function removeESPForPlayer(p)
    local c = espObjects[p]; if not c then return end
    if c.highlight then c.highlight:Destroy() end
    if c.bbGui     then c.bbGui:Destroy()     end
    espObjects[p] = nil
end

local function clearAllESP() for p in pairs(espObjects) do removeESPForPlayer(p) end end

local function refreshESPVisibility()
    for _, c in pairs(espObjects) do
        if c.highlight then c.highlight.Enabled = state.espBoxes    end
        if c.nameLabel then c.nameLabel.Visible  = state.espNames    end
        if c.distLabel then c.distLabel.Visible  = state.espDistance end
        if c.hpLabel   then c.hpLabel.Visible    = state.espHealth   end
    end
end

RunService.RenderStepped:Connect(function()
    if not state.espEnabled then return end
    local myHRP = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    for p, c in pairs(espObjects) do
        if not p or not p.Parent then removeESPForPlayer(p) continue end
        local char = p.Character; if not char then continue end
        local hrp  = char:FindFirstChild("HumanoidRootPart")
        local hum  = char:FindFirstChildOfClass("Humanoid")
        if hrp and myHRP then
            local dist = math.floor((hrp.Position - myHRP.Position).Magnitude)
            local ok   = dist <= state.espMaxDist
            if c.highlight then c.highlight.Enabled = ok and state.espBoxes end
            if c.bbGui     then c.bbGui.Enabled     = ok                    end
            if ok and c.distLabel and state.espDistance then
                c.distLabel.Text = dist .. " studs"
            end
        end
        if hum and c.hpLabel and state.espHealth then
            local ratio = hum.Health / math.max(hum.MaxHealth, 1)
            c.hpLabel.Text       = "HP: "..math.floor(hum.Health).."/"..math.floor(hum.MaxHealth)
            c.hpLabel.TextColor3 = ratio > 0.6 and Theme.Success or ratio > 0.3 and Color3.fromRGB(250,204,21) or Theme.Danger
        end
    end
end)

local function toggleESP(v)
    state.espEnabled = v
    if v then
        for _, p in pairs(Players:GetPlayers()) do buildESPForPlayer(p) end
        refreshESPVisibility()
        Library:Notify("ESP", "Entity tracking active", 2)
    else
        clearAllESP()
        Library:Notify("ESP", "Entity tracking disabled", 2)
    end
end

Players.PlayerAdded:Connect(function(p)
    if state.espEnabled then task.wait(1); buildESPForPlayer(p); refreshESPVisibility() end
end)
Players.PlayerRemoving:Connect(function(p) removeESPForPlayer(p) end)

